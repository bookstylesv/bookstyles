// ════════════════════════════════════════════════════
// Speeddan Barbería — Prisma Schema
// Prefijo barber_ en tablas para convivir con otros
// proyectos en la misma instancia Neon PostgreSQL.
// ════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────────────

enum BarberPlan {
  TRIAL
  BASIC
  PRO
  ENTERPRISE
}

enum BarberTenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum BarberUserRole {
  OWNER    // Dueño del negocio / super-admin del tenant
  ADMIN    // Administrador del sistema (acceso completo sin ser dueño)
  GERENTE  // Gerente de sucursal (acceso operativo, sin configuración)
  IT       // Soporte técnico / configuración
  BARBER   // Estilista / barbero (solo POS y su perfil)
  CLIENT   // Cliente del negocio (portal de citas)
}

enum BarberAppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum BarberPaymentMethod {
  CASH
  CARD
  TRANSFER
  QR
}

enum BarberPaymentStatus {
  PENDING
  PAID
  REFUNDED
}

enum BusinessType {
  BARBERIA
  SALON
}

// ──────────────────────────────────────────────────────
// TENANT — cada barbería es un tenant aislado
// themeConfig: JSON con overrides de CSS variables
// Ejemplo: { "--brand-primary": "213 94% 47%" }
// ──────────────────────────────────────────────────────

model BarberTenant {
  id          Int                @id @default(autoincrement())
  slug        String             @unique
  name        String
  plan        BarberPlan         @default(TRIAL)
  planSlug    String?            // slug del plan custom asignado (override del enum plan)
  status      BarberTenantStatus @default(TRIAL)
  trialEndsAt DateTime?
  paidUntil   DateTime?
  suspendedAt DateTime?
  maxBarbers  Int                @default(3)
  themeConfig   Json               @default("{}")
  modules       Json               @default("{\"appointments\":true,\"billing\":false,\"loyalty\":false,\"products\":false}")
  businessHours Json               @default("[]")
  logoUrl     String?
  address     String?
  phone       String?
  email       String?
  city        String?
  country      String             @default("SV")
  businessType BusinessType       @default(BARBERIA)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?

  users        BarberUser[]
  barbers      Barber[]
  services     BarberService[]
  appointments BarberAppointment[]
  payments     BarberPayment[]
  reviews      BarberReview[]
  sessions     BarberSession[]

  // Módulos de compras / inventario / gastos
  proveedores        BarberProveedor[]
  categoriaProductos BarberCategoriaProducto[]
  productos          BarberProducto[]
  compras            BarberCompra[]
  categoriaGastos    BarberCategoriaGasto[]
  categoriaServicios BarberCategoriaServicio[]
  gastos             BarberGasto[]

  // Módulo planilla
  configPlanilla BarberConfigPlanilla[] @relation("ConfigPlanillaTenant")
  planillas      BarberPlanilla[]       @relation("PlanillaTenant")

  // Módulo POS
  turnos        BarberTurno[]
  ventas        BarberVenta[]
  notasCredito  BarberNotaCredito[]
  correlativos  BarberCorrelativo[]
  dayOverrides  BarberDayOverride[]

  // Módulo Loyalty
  loyaltyTarjetas BarberLoyaltyTarjeta[]

  // Módulo Unidades de Medida
  unidadesMedida BarberUnidadMedida[]

  // Cargos de empleados
  cargos BarberCargo[]

  // Sucursales
  branches       BarberBranch[]

  // Inventario por sucursal
  stockSucursal  BarberStockSucursal[]
  transferencias BarberTransferencia[]

  @@map("barber_tenants")
}

// ──────────────────────────────────────────────────────
// PLAN CONFIG — configuración de cada plan (módulos,
// límites). Administrado desde el panel de control vía
// endpoints superadmin.
// ──────────────────────────────────────────────────────

model BarberPlanConfig {
  id          Int         @id @default(autoincrement())
  slug        String      @unique               // identificador único — "basic", "pro", "premium-v2"…
  plan        BarberPlan?                       // solo para los 4 planes del sistema (nullable en custom)
  displayName String
  description String?
  maxBarbers  Int         @default(3)
  maxBranches Int         @default(1)
  modules     Json        @default("{}")
  price       Decimal?    @db.Decimal(10, 2)
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("barber_plan_configs")
}

// ──────────────────────────────────────────────────────
// BRANCH — sucursales de un tenant
// isHeadquarters=true → casa matriz (creada automáticamente)
// Datos operativos (ventas, citas, etc.) se aislan por branchId.
// Catálogo de servicios y clientes son compartidos (tenantId).
// ──────────────────────────────────────────────────────

enum BarberBranchStatus {
  ACTIVE
  INACTIVE
}

model BarberBranch {
  id              Int                @id @default(autoincrement())
  tenantId        Int
  tenant          BarberTenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  slug            String             // "principal", "centro", "escalon"
  address         String?
  phone           String?
  email           String?
  city            String?
  businessHours   Json               @default("[]")
  isHeadquarters  Boolean            @default(false)
  status          BarberBranchStatus @default(ACTIVE)
  managerId       Int?               // FK a BarberUser (encargado)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  barberAssignments BarberBranchAssignment[]

  // Relaciones de datos operativos aislados por sucursal
  appointments  BarberAppointment[]
  turnos        BarberTurno[]
  ventas        BarberVenta[]
  gastos        BarberGasto[]
  compras       BarberCompra[]
  planillas     BarberPlanilla[]
  kardex        BarberKardex[]
  dayOverrides  BarberDayOverride[]
  correlativos  BarberCorrelativo[]
  notasCredito  BarberNotaCredito[]

  // Inventario por sucursal
  stockSucursal        BarberStockSucursal[]
  transferenciasOrigen BarberTransferencia[] @relation("TransferenciaOrigen")
  transferenciasDest   BarberTransferencia[] @relation("TransferenciaDestino")

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("barber_branches")
}

// ──────────────────────────────────────────────────────
// BRANCH ASSIGNMENT — qué barberos trabajan en qué sucursales
// Un barbero puede estar asignado a varias sucursales.
// isPrimary = sucursal predeterminada del barbero.
// ──────────────────────────────────────────────────────

model BarberBranchAssignment {
  id        Int          @id @default(autoincrement())
  branchId  Int
  branch    BarberBranch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  barberId  Int
  barber    Barber       @relation(fields: [barberId], references: [id], onDelete: Cascade)
  isPrimary Boolean      @default(false)
  createdAt DateTime     @default(now())

  @@unique([branchId, barberId])
  @@map("barber_branch_assignments")
}

// ──────────────────────────────────────────────────────
// USER — dueño, barbero o cliente del tenant
// @@unique([email, tenantId]) permite mismo email en
// diferentes barberías sin conflicto.
// ──────────────────────────────────────────────────────

model BarberUser {
  id        Int            @id @default(autoincrement())
  tenantId  Int
  tenant    BarberTenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email     String
  password  String
  fullName        String
  phone           String?
  // ── Datos fiscales DTE (CAT-009/012/013 MH El Salvador) ──
  tipoDocumento   String?  // "13"=DUI, "36"=NIT, "37"=Pasaporte, "03"=Cédula ext.
  numDocumento    String?  // número sin guiones
  nrc             String?  // NRC para contribuyentes (NIT)
  nombreComercial String?  // razón comercial (empresas)
  departamentoCod String?  // CAT-012
  municipioCod    String?  // CAT-013
  complemento     String?  // dirección adicional
  // ── Descuento por convenio/cliente ──
  descuentoTipo   String?  // "PORCENTAJE" | "MONTO"
  descuentoValor  Float?   // valor numérico (ej: 10 para 10% o $10.00)
  avatarUrl       String?
  role      BarberUserRole @default(CLIENT)
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  barberProfile  Barber?
  appointments   BarberAppointment[] @relation("ClientAppointments")
  sessions       BarberSession[]
  // POS
  turnosAbiertos BarberTurno[]       @relation("TurnoApertura")
  turnosCerrados BarberTurno[]       @relation("TurnoCierre")
  ventasCliente  BarberVenta[]       @relation("VentaCliente")

  @@unique([email, tenantId])
  @@map("barber_users")
}

// ──────────────────────────────────────────────────────
// SESSION — refresh tokens persistidos en BD
// Se limpian automáticamente al expirar (cron futuro)
// ──────────────────────────────────────────────────────

model BarberSession {
  id           String       @id @default(cuid())
  userId       Int
  user         BarberUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId     Int
  tenant       BarberTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshToken String       @unique
  expiresAt    DateTime
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime     @default(now())

  @@map("barber_sessions")
}

// ──────────────────────────────────────────────────────
// BARBER — perfil profesional del barbero
// ──────────────────────────────────────────────────────

model Barber {
  id          Int          @id @default(autoincrement())
  tenantId    Int
  tenant      BarberTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      Int          @unique
  user        BarberUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio         String?
  cargo       String?      @default("Barbero")
  specialties String[]     @default([])
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  schedules         BarberSchedule[]
  appointments      BarberAppointment[]
  reviews           BarberReview[]
  configPlanilla    BarberConfigBarbero?
  detallesVenta     BarberDetalleVenta[]
  branchAssignments BarberBranchAssignment[]

  @@map("barbers")
}

// ──────────────────────────────────────────────────────
// CARGO — cargos/puestos de empleados por tenant
// Cada barbería define sus propios cargos (Barbero, Estilista, etc.)
// ──────────────────────────────────────────────────────

model BarberCargo {
  id          Int          @id @default(autoincrement())
  tenantId    Int
  tenant      BarberTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nombre      String
  descripcion String?
  activo      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([tenantId, nombre])
  @@index([tenantId])
  @@map("barber_cargos")
}

// ──────────────────────────────────────────────────────
// SCHEDULE — horarios de trabajo por día de la semana
// ──────────────────────────────────────────────────────

model BarberSchedule {
  id        Int     @id @default(autoincrement())
  barberId  Int
  barber    Barber  @relation(fields: [barberId], references: [id], onDelete: Cascade)
  dayOfWeek Int     // 0=Dom, 1=Lun ... 6=Sáb
  startTime String  // "09:00"
  endTime   String  // "18:00"
  active    Boolean @default(true)

  @@unique([barberId, dayOfWeek])
  @@map("barber_schedules")
}

// ──────────────────────────────────────────────────────
// SERVICE — servicios que ofrece la barbería
// ──────────────────────────────────────────────────────

model BarberService {
  id          Int          @id @default(autoincrement())
  tenantId    Int
  tenant      BarberTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price           Decimal  @db.Decimal(10, 2)
  comisionTipo    String   @default("NINGUNA") // NINGUNA | MONTO_FIJO | PORCENTAJE
  comisionBarbero Decimal  @default(0) @db.Decimal(10, 2)
  duration        Int      // minutos
  imageUrl        String?
  category        String?  // "cabello" | "barba" | "combo" | "tratamiento"
  active          Boolean  @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  appointments  BarberAppointment[]
  detallesVenta BarberDetalleVenta[]

  @@index([tenantId, active])
  @@map("barber_services")
}

// ──────────────────────────────────────────────────────
// APPOINTMENT — citas reservadas
// @@unique([barberId, startTime]) previene doble reserva
// a nivel de base de datos (race condition fix)
// ──────────────────────────────────────────────────────

model BarberAppointment {
  id           Int                     @id @default(autoincrement())
  tenantId     Int
  tenant       BarberTenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId     Int?
  branch       BarberBranch?           @relation(fields: [branchId], references: [id])
  clientId     Int
  client       BarberUser              @relation("ClientAppointments", fields: [clientId], references: [id])
  barberId     Int
  barber       Barber                  @relation(fields: [barberId], references: [id])
  serviceId    Int
  service      BarberService           @relation(fields: [serviceId], references: [id])
  startTime    DateTime
  endTime      DateTime
  status       BarberAppointmentStatus @default(PENDING)
  notes        String?
  cancelReason String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  payment BarberPayment?
  review  BarberReview?

  @@unique([barberId, startTime])
  @@index([tenantId, status])
  @@index([branchId])
  @@map("barber_appointments")
}

// ──────────────────────────────────────────────────────
// PAYMENT — caja y registro de cobros
// ──────────────────────────────────────────────────────

model BarberPayment {
  id            Int                 @id @default(autoincrement())
  tenantId      Int
  tenant        BarberTenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointmentId Int                 @unique
  appointment   BarberAppointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  amount        Decimal             @db.Decimal(10, 2)
  method        BarberPaymentMethod @default(CASH)
  status        BarberPaymentStatus @default(PENDING)
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime            @default(now())

  @@map("barber_payments")
}

// ──────────────────────────────────────────────────────
// REVIEW — calificaciones post-cita (1-5 estrellas)
// ──────────────────────────────────────────────────────

model BarberReview {
  id            Int               @id @default(autoincrement())
  tenantId      Int
  tenant        BarberTenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointmentId Int               @unique
  appointment   BarberAppointment @relation(fields: [appointmentId], references: [id])
  barberId      Int
  barber        Barber            @relation(fields: [barberId], references: [id])
  rating        Int               // 1-5
  comment       String?
  createdAt     DateTime          @default(now())

  @@map("barber_reviews")
}

// ══════════════════════════════════════════════════════
// MÓDULO PROVEEDORES
// ══════════════════════════════════════════════════════

model BarberProveedor {
  id           Int          @id @default(autoincrement())
  tenantId     Int
  tenant       BarberTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nombre       String
  nit          String?
  nrc          String?
  correo       String?
  telefono     String?
  tipo         String       @default("NACIONAL") // NACIONAL | INTERNACIONAL
  contacto     String?
  plazoCredito Int          @default(0)           // días de crédito
  direccion    String?
  activo       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  compras BarberCompra[]

  @@index([tenantId])
  @@map("barber_proveedores")
}

// ══════════════════════════════════════════════════════
// MÓDULO PRODUCTOS / INVENTARIO
// ══════════════════════════════════════════════════════

model BarberCategoriaProducto {
  id        Int       @id @default(autoincrement())
  tenantId  Int
  tenant    BarberTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nombre    String
  color     String    @default("blue")
  activa    Boolean   @default(true)
  createdAt DateTime  @default(now())

  productos BarberProducto[]

  @@unique([tenantId, nombre])
  @@map("barber_categorias_producto")
}

model BarberProducto {
  id            Int                      @id @default(autoincrement())
  tenantId      Int
  tenant        BarberTenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  codigo        String
  nombre        String
  descripcion   String?
  categoriaId   Int?
  categoria     BarberCategoriaProducto? @relation(fields: [categoriaId], references: [id])
  precioVenta    Decimal                  @db.Decimal(10, 2)
  costoPromedio  Decimal                  @default(0) @db.Decimal(10, 2)
  comisionTipo   String                   @default("NINGUNA") // NINGUNA | MONTO_FIJO | PORCENTAJE
  precioComision Decimal?                 @db.Decimal(10, 2)
  stockMinimo    Decimal                  @default(0) @db.Decimal(10, 2)
  stockActual   Decimal                  @default(0) @db.Decimal(10, 2)
  unidadMedida  String                   @default("UNIDAD")
  // Unidades fraccionadas
  unidadCompra     String                @default("UNIDAD")  // ej: "Botella", "Galón", "Caja"
  unidadVentaId    Int?                                       // FK a BarberUnidadMedida
  unidadVenta      BarberUnidadMedida?   @relation(fields: [unidadVentaId], references: [id])
  factorConversion Decimal               @default(1) @db.Decimal(10, 4) // cuántas unidVenta por 1 unidCompra
  activo        Boolean                  @default(true)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  kardex         BarberKardex[]
  detallesCompra BarberDetalleCompra[]
  detallesVenta  BarberDetalleVenta[]
  stockSucursal  BarberStockSucursal[]
  transferencias BarberTransferencia[]

  @@unique([tenantId, codigo])
  @@index([tenantId])
  @@map("barber_productos")
}

model BarberKardex {
  id             Int            @id @default(autoincrement())
  tenantId       Int
  branchId       Int?
  branch         BarberBranch?  @relation(fields: [branchId], references: [id])
  productoId     Int
  producto       BarberProducto @relation(fields: [productoId], references: [id])
  tipoMovimiento String         // COMPRA | ENTRADA | SALIDA | AJUSTE | ANULACION
  referencia     String
  cantidad       Decimal        @db.Decimal(10, 2)
  costoUnitario  Decimal        @db.Decimal(10, 2)
  costoTotal     Decimal        @db.Decimal(10, 2)
  stockAnterior  Decimal        @db.Decimal(10, 2)
  stockNuevo     Decimal        @db.Decimal(10, 2)
  notas          String?
  fecha          DateTime       @default(now())
  createdAt      DateTime       @default(now())

  @@index([tenantId])
  @@index([productoId])
  @@index([branchId])
  @@map("barber_kardex")
}

// ══════════════════════════════════════════════════════
// INVENTARIO POR SUCURSAL
// BarberStockSucursal: stock actual de cada producto en cada sucursal
// BarberTransferencia: movimiento de stock entre sucursales
// ══════════════════════════════════════════════════════

model BarberStockSucursal {
  id          Int            @id @default(autoincrement())
  tenantId    Int
  tenant      BarberTenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    Int
  branch      BarberBranch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  productoId  Int
  producto    BarberProducto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  stockActual Decimal        @default(0) @db.Decimal(10, 2)
  updatedAt   DateTime       @updatedAt

  @@unique([branchId, productoId])
  @@index([tenantId])
  @@index([branchId])
  @@index([productoId])
  @@map("barber_stock_sucursal")
}

model BarberTransferencia {
  id            Int            @id @default(autoincrement())
  tenantId      Int
  tenant        BarberTenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productoId    Int
  producto      BarberProducto @relation(fields: [productoId], references: [id])
  fromBranchId  Int
  fromBranch    BarberBranch   @relation("TransferenciaOrigen", fields: [fromBranchId], references: [id])
  toBranchId    Int
  toBranch      BarberBranch   @relation("TransferenciaDestino", fields: [toBranchId], references: [id])
  cantidad      Decimal        @db.Decimal(10, 2)
  costoUnitario Decimal        @db.Decimal(10, 2)
  notas         String?
  estado        String         @default("COMPLETADA") // COMPLETADA | ANULADA
  fecha         DateTime       @default(now())
  createdAt     DateTime       @default(now())

  @@index([tenantId])
  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([productoId])
  @@map("barber_transferencias")
}

// ══════════════════════════════════════════════════════
// MÓDULO UNIDADES DE MEDIDA (catálogo por tenant)
// ══════════════════════════════════════════════════════

model BarberUnidadMedida {
  id        Int           @id @default(autoincrement())
  tenantId  Int
  tenant    BarberTenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nombre    String        // "Onza", "Vaso", "Cucharada", "Libra"
  simbolo   String?       // "oz", "vaso", "cdta" (opcional)
  activa    Boolean       @default(true)
  createdAt DateTime      @default(now())

  productos BarberProducto[]

  @@unique([tenantId, nombre])
  @@index([tenantId])
  @@map("barber_unidades_medida")
}

// ══════════════════════════════════════════════════════
// MÓDULO COMPRAS
// ══════════════════════════════════════════════════════

model BarberCompra {
  id              Int              @id @default(autoincrement())
  tenantId        Int
  tenant          BarberTenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId        Int?
  branch          BarberBranch?    @relation(fields: [branchId], references: [id])
  proveedorId     Int?
  proveedor       BarberProveedor? @relation(fields: [proveedorId], references: [id])
  numeroDocumento String
  tipoDocumento   String           // FACTURA | CCF | RECIBO | TICKET | NOTA
  tipoCompra      String           @default("PRODUCTO") // PRODUCTO | GASTO_SERVICIO
  condicionPago   String           @default("CONTADO")  // CONTADO | CREDITO
  fecha           DateTime
  subtotal        Decimal          @db.Decimal(10, 2)
  iva             Decimal          @db.Decimal(10, 2)
  total           Decimal          @db.Decimal(10, 2)
  estado          String           @default("REGISTRADA") // REGISTRADA | PAGADA | ANULADA
  notas           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  detalles BarberDetalleCompra[]
  pagos    BarberPagoCxP[]

  @@index([tenantId])
  @@index([branchId])
  @@map("barber_compras")
}

model BarberDetalleCompra {
  id            Int             @id @default(autoincrement())
  compraId      Int
  compra        BarberCompra    @relation(fields: [compraId], references: [id], onDelete: Cascade)
  productoId    Int?
  producto      BarberProducto? @relation(fields: [productoId], references: [id])
  descripcion   String?
  cantidad      Decimal         @db.Decimal(10, 2)
  costoUnitario Decimal         @db.Decimal(10, 2)
  descuento     Decimal         @default(0) @db.Decimal(10, 2)
  subtotal      Decimal         @db.Decimal(10, 2)

  @@map("barber_detalles_compra")
}

// ══════════════════════════════════════════════════════
// MÓDULO CxP — CUENTAS POR PAGAR
// ══════════════════════════════════════════════════════

model BarberPagoCxP {
  id         Int          @id @default(autoincrement())
  tenantId   Int
  compraId   Int
  compra     BarberCompra @relation(fields: [compraId], references: [id])
  monto      Decimal      @db.Decimal(10, 2)
  metodoPago String       // CASH | CARD | TRANSFER | QR
  referencia String?
  notas      String?
  fecha      DateTime     @default(now())
  createdAt  DateTime     @default(now())

  @@index([tenantId])
  @@map("barber_pagos_cxp")
}

// ══════════════════════════════════════════════════════
// MÓDULO GASTOS
// ══════════════════════════════════════════════════════

model BarberCategoriaGasto {
  id          Int          @id @default(autoincrement())
  tenantId    Int
  tenant      BarberTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nombre      String
  descripcion String?
  color       String       @default("#0d9488")
  activo      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  gastos BarberGasto[]

  @@unique([tenantId, nombre])
  @@index([tenantId])
  @@map("barber_categorias_gasto")
}

model BarberCategoriaServicio {
  id        Int          @id @default(autoincrement())
  tenantId  Int
  tenant    BarberTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nombre    String
  color     String       @default("blue")
  activo    Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([tenantId, nombre])
  @@index([tenantId])
  @@map("barber_categorias_servicio")
}

model BarberGasto {
  id          Int                 @id @default(autoincrement())
  tenantId    Int
  tenant      BarberTenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    Int?
  branch      BarberBranch?       @relation(fields: [branchId], references: [id])
  categoriaId Int
  categoria   BarberCategoriaGasto @relation(fields: [categoriaId], references: [id])
  descripcion String
  monto       Decimal             @db.Decimal(10, 2)
  fecha       DateTime
  notas       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([tenantId])
  @@index([branchId])
  @@map("barber_gastos")
}

// ══════════════════════════════════════════════════════
// MÓDULO PLANILLA
// ══════════════════════════════════════════════════════

model BarberConfigPlanilla {
  id          Int          @id @default(autoincrement())
  tenantId    Int
  tenant      BarberTenant @relation("ConfigPlanillaTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  clave       String
  valor       Decimal      @db.Decimal(10, 4)
  descripcion String?
  topeMaximo  Decimal?     @db.Decimal(10, 2)
  updatedAt   DateTime     @updatedAt

  @@unique([tenantId, clave])
  @@index([tenantId])
  @@map("barber_config_planilla")
}

model BarberConfigBarbero {
  id                 Int       @id @default(autoincrement())
  tenantId           Int
  barberoId          Int       @unique
  barbero            Barber    @relation(fields: [barberoId], references: [id], onDelete: Cascade)
  tipoPago           String    @default("FIJO")  // FIJO | POR_DIA | POR_SEMANA | POR_HORA | POR_SERVICIO
  salarioBase        Decimal   @default(0) @db.Decimal(10, 2)
  valorPorUnidad     Decimal   @default(0) @db.Decimal(10, 2)
  porcentajeServicio Decimal   @default(0) @db.Decimal(5, 2)
  aplicaRenta        Boolean   @default(true)
  fechaIngreso       DateTime? // fecha de contratación (para aguinaldo/vacaciones/quincena25)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([tenantId])
  @@map("barber_config_barbero")
}

model BarberPlanilla {
  id               Int                    @id @default(autoincrement())
  tenantId         Int
  tenant           BarberTenant           @relation("PlanillaTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  branchId         Int?
  branch           BarberBranch?          @relation(fields: [branchId], references: [id])
  periodo          String                 // YYYY-MM
  estado           String                 @default("BORRADOR")  // BORRADOR | APROBADA | PAGADA
  totalBruto       Decimal                @default(0) @db.Decimal(10, 2)
  totalISS         Decimal                @default(0) @db.Decimal(10, 2)
  totalAFP         Decimal                @default(0) @db.Decimal(10, 2)
  totalRenta       Decimal                @default(0) @db.Decimal(10, 2)
  totalDeducciones Decimal                @default(0) @db.Decimal(10, 2)
  totalNeto        Decimal                @default(0) @db.Decimal(10, 2)
  totalPatronalISS Decimal                @default(0) @db.Decimal(10, 2)
  totalPatronalAFP Decimal                @default(0) @db.Decimal(10, 2)
  totalINSAFORP    Decimal                @default(0) @db.Decimal(10, 2)
  notas            String?
  detalles         BarberDetallePlanilla[]
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@unique([tenantId, periodo])
  @@index([tenantId])
  @@index([branchId])
  @@map("barber_planillas")
}

model BarberDetallePlanilla {
  id               Int            @id @default(autoincrement())
  planillaId       Int
  planilla         BarberPlanilla @relation(fields: [planillaId], references: [id], onDelete: Cascade)
  barberoId        Int
  nombre           String
  tipoPago         String
  unidades         Decimal        @default(0) @db.Decimal(10, 2)
  salarioBruto     Decimal        @db.Decimal(10, 2)
  isss             Decimal        @default(0) @db.Decimal(10, 2)
  afp              Decimal        @default(0) @db.Decimal(10, 2)
  renta            Decimal        @default(0) @db.Decimal(10, 2)
  otrasDeducciones Decimal        @default(0) @db.Decimal(10, 2)
  totalDeducciones Decimal        @default(0) @db.Decimal(10, 2)
  salarioNeto      Decimal        @default(0) @db.Decimal(10, 2)
  isssPatronal     Decimal        @default(0) @db.Decimal(10, 2)
  afpPatronal      Decimal        @default(0) @db.Decimal(10, 2)
  insaforp         Decimal        @default(0) @db.Decimal(10, 2)

  @@map("barber_detalles_planilla")
}

// ══════════════════════════════════════════════════════
// MÓDULO POS — PUNTO DE VENTA
// ══════════════════════════════════════════════════════

enum BarberTurnoEstado {
  ABIERTO
  CERRADO
}

enum BarberVentaEstado {
  ACTIVA
  ANULADA
}

enum LoyaltyTipo {
  SELLOS
  PUNTOS
}

enum LoyaltyEstado {
  ACTIVA
  PENDIENTE_CANJE
}

// Turno de caja — controla apertura/cierre y arqueo
model BarberTurno {
  id                      Int               @id @default(autoincrement())
  tenantId                Int
  tenant                  BarberTenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId                Int?
  branch                  BarberBranch?     @relation(fields: [branchId], references: [id])
  usuarioAperturaId       Int
  usuarioApertura         BarberUser        @relation("TurnoApertura", fields: [usuarioAperturaId], references: [id])
  usuarioCierreId         Int?
  usuarioCierre           BarberUser?       @relation("TurnoCierre", fields: [usuarioCierreId], references: [id])
  fechaApertura           DateTime          @default(now())
  fechaCierre             DateTime?
  montoInicial            Decimal           @default(0) @db.Decimal(10, 2)
  // Totales por método (calculados al cierre)
  totalEfectivo           Decimal           @default(0) @db.Decimal(10, 2)
  totalTarjeta            Decimal           @default(0) @db.Decimal(10, 2)
  totalTransferencia      Decimal           @default(0) @db.Decimal(10, 2)
  totalQR                 Decimal           @default(0) @db.Decimal(10, 2)
  totalVentas             Decimal           @default(0) @db.Decimal(10, 2)
  cantidadServicios       Int               @default(0)
  // Arqueo de cierre
  montoEsperado           Decimal?          @db.Decimal(10, 2) // sistema calcula
  montoContado            Decimal?          @db.Decimal(10, 2) // cajero cuenta
  diferencia              Decimal?          @db.Decimal(10, 2) // sobrante(+)/faltante(-)
  arqueoCaja              Json?             // billetes y monedas: {"billetes":{"100":2,...},"monedas":{"0.25":4,...}}
  notasCierre             String?
  estado                  BarberTurnoEstado @default(ABIERTO)
  createdAt               DateTime          @default(now())

  ventas BarberVenta[]

  @@index([tenantId])
  @@index([branchId])
  @@map("barber_turnos")
}

// Venta POS — cada transacción del cajero
model BarberVenta {
  id               Int               @id @default(autoincrement())
  tenantId         Int
  tenant           BarberTenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId         Int?
  branch           BarberBranch?     @relation(fields: [branchId], references: [id])
  turnoId          Int
  turno            BarberTurno       @relation(fields: [turnoId], references: [id])
  numero           Int               // correlativo interno del tenant
  // DTE
  codigoGeneracion String            @unique // UUID v4
  numeroControl    String?           // DTE-01-XXXX-000000001
  tipoDte          String            @default("01") // 01=Factura, 03=CCF
  // Cliente (null = Consumidor Final)
  clienteId        Int?
  cliente          BarberUser?       @relation("VentaCliente", fields: [clienteId], references: [id])
  clienteNombre    String?           // snapshot "Consumidor Final" o nombre
  clienteDocumento String?           // DUI o NIT
  clienteNrc       String?           // NRC (solo para CCF)
  // Totales
  subtotal         Decimal           @db.Decimal(10, 2)
  descuentoTotal   Decimal           @default(0) @db.Decimal(10, 2)
  totalGravado     Decimal           @default(0) @db.Decimal(10, 2)
  totalExento      Decimal           @default(0) @db.Decimal(10, 2)
  iva              Decimal           @default(0) @db.Decimal(10, 2)
  total            Decimal           @db.Decimal(10, 2)
  // Vínculo con cita (opcional)
  appointmentId    Int?
  // Estado y modo
  estado           BarberVentaEstado @default(ACTIVA)
  simulada         Boolean           @default(true)
  motivoAnulacion  String?
  // DTE JSON completo (guardado en BD para visualización sin filesystem)
  dteJson          Json?
  // Futuro MH
  selloRecepcion   String?
  mhEstado         String?
  createdAt        DateTime          @default(now())

  detalles     BarberDetalleVenta[]
  pagos        BarberPagoVenta[]
  notasCredito BarberNotaCredito[]

  @@unique([tenantId, numero])
  @@index([tenantId])
  @@index([tenantId, estado])
  @@index([turnoId])
  @@index([branchId])
  @@map("barber_ventas")
}

// Línea de detalle — cada servicio o producto con su barbero (opcional en productos)
model BarberDetalleVenta {
  id             Int             @id @default(autoincrement())
  ventaId        Int
  venta          BarberVenta     @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  numItem        Int             // 1, 2, 3...
  barberoId      Int?
  barbero        Barber?         @relation(fields: [barberoId], references: [id])
  servicioId     Int?
  servicio       BarberService?  @relation(fields: [servicioId], references: [id])
  productoId     Int?
  producto       BarberProducto? @relation(fields: [productoId], references: [id])
  descripcion    String          // snapshot del nombre del servicio/producto
  cantidad       Int             @default(1)
  precioUnitario Decimal         @db.Decimal(10, 2)
  descuento      Decimal         @default(0) @db.Decimal(10, 2)
  subtotal       Decimal         @db.Decimal(10, 2)
  esGravado      Boolean         @default(false)
  ivaItem        Decimal         @default(0) @db.Decimal(10, 2)
  comisionLinea  Decimal         @default(0) @db.Decimal(10, 2)

  @@map("barber_detalles_venta")
}

// Formas de pago por venta (puede ser mixto)
model BarberPagoVenta {
  id         Int                 @id @default(autoincrement())
  ventaId    Int
  venta      BarberVenta         @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  metodo     BarberPaymentMethod
  monto      Decimal             @db.Decimal(10, 2)
  recibido   Decimal?            @db.Decimal(10, 2) // solo efectivo: cuánto entregó el cliente
  vuelto     Decimal?            @db.Decimal(10, 2) // recibido - monto
  referencia String?             // # de tarjeta, # transferencia

  @@map("barber_pagos_venta")
}

// Nota de Crédito (DTE-05)
model BarberNotaCredito {
  id               Int          @id @default(autoincrement())
  tenantId         Int
  tenant           BarberTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId         Int?
  branch           BarberBranch? @relation(fields: [branchId], references: [id])
  ventaOriginalId  Int
  ventaOriginal    BarberVenta @relation(fields: [ventaOriginalId], references: [id])
  codigoGeneracion String      @unique
  numeroControl    String?
  motivo           String
  total            Decimal     @db.Decimal(10, 2)
  estado           String      @default("ACTIVA")
  simulada         Boolean     @default(true)
  createdAt        DateTime    @default(now())

  @@index([tenantId])
  @@map("barber_notas_credito")
}

// Correlativo DTE — numeración secuencial por tipo y año fiscal
model BarberCorrelativo {
  id         Int           @id @default(autoincrement())
  tenantId   Int
  tenant     BarberTenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId   Int?
  branch     BarberBranch? @relation(fields: [branchId], references: [id])
  tipoDte    String        // "01", "03", "05", "interno"
  anioFiscal Int
  siguiente  Int           @default(1)

  @@unique([tenantId, tipoDte, anioFiscal])
  @@index([tenantId])
  @@index([branchId])
  @@map("barber_correlativos")
}

// ══════════════════════════════════════════════════════
// MÓDULO BOOKING PÚBLICO — excepciones de horario
// ══════════════════════════════════════════════════════

model BarberDayOverride {
  id        Int           @id @default(autoincrement())
  tenantId  Int
  tenant    BarberTenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId  Int?
  branch    BarberBranch? @relation(fields: [branchId], references: [id])
  date      DateTime      @db.Date
  isOpen    Boolean       @default(false)
  openTime  String?       // "07:00" si difiere del default
  closeTime String?       // "12:00" si difiere del default
  reason    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([tenantId, date])
  @@index([tenantId])
  @@index([branchId])
  @@map("barber_day_overrides")
}


// ══════════════════════════════════════════════════════
// MÓDULO LOYALTY — Puntos y Tarjetas de fidelización
// ══════════════════════════════════════════════════════

model BarberLoyaltyTarjeta {
  id             Int            @id @default(autoincrement())
  tenantId       Int
  tenant         BarberTenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  codigo         String         // Código único impreso en tarjeta física (ej: "GOLD-001")
  nombre         String         // Nombre descriptivo: "Tarjeta Cortes VIP"
  tipo           LoyaltyTipo    // SELLOS | PUNTOS
  meta           Int            // Objetivo: 10 sellos ó 100 puntos
  dolarsPorPunto Decimal?       @db.Decimal(10, 2) // Solo PUNTOS: cuántos $ = 1 punto (ej: 5.00)
  saldoActual    Int            @default(0)
  estado         LoyaltyEstado  @default(ACTIVA)
  createdAt      DateTime       @default(now())
  movimientos    BarberLoyaltyMovimiento[]

  @@unique([tenantId, codigo])
  @@index([tenantId])
  @@map("barber_loyalty_tarjetas")
}

model BarberLoyaltyMovimiento {
  id         Int                  @id @default(autoincrement())
  tenantId   Int
  tarjetaId  Int
  tarjeta    BarberLoyaltyTarjeta @relation(fields: [tarjetaId], references: [id], onDelete: Cascade)
  ventaId    Int?                 // Venta POS que generó el movimiento
  tipo       String               // ACUMULO | CANJE
  cantidad   Int                  // +N al acumular, valor negativo al canjear
  nota       String?
  createdAt  DateTime             @default(now())

  @@index([tarjetaId])
  @@map("barber_loyalty_movimientos")
}

// ══════════════════════════════════════════════════════
// CONFIGURACIÓN GLOBAL — branding del login
// ══════════════════════════════════════════════════════

model BarberGlobalConfig {
  id        Int      @id @default(1)
  brandName String   @default("Speeddan")
  tagline   String   @default("Sistema de gestión para barberías")
  features  Json     @default("[{\"title\":\"Gestión de Citas\",\"description\":\"Agenda online en tiempo real\"},{\"title\":\"Reportes y Caja\",\"description\":\"Control financiero completo\"},{\"title\":\"Gestión de Clientes\",\"description\":\"Historial y fidelización\"}]")
  updatedAt DateTime @updatedAt

  @@map("barber_global_config")
}

// ══════════════════════════════════════════════════════
// CATÁLOGO MH — Departamentos y Municipios El Salvador
// CAT-012 (departamentos) y CAT-013 (municipios)
// Sin tenantId — catálogo global compartido
// ══════════════════════════════════════════════════════

model BarberDepartamento {
  id         Int               @id @default(autoincrement())
  codigo     String            @unique  // "01"-"14"
  nombre     String
  municipios BarberMunicipio[]

  @@map("barber_departamentos")
}

model BarberMunicipio {
  id              Int                @id @default(autoincrement())
  codigo          String             // código MH (único dentro del departamento)
  nombre          String
  departamentoCod String
  departamento    BarberDepartamento @relation(fields: [departamentoCod], references: [codigo])

  @@unique([departamentoCod, codigo])
  @@map("barber_municipios")
}

// ══════════════════════════════════════════════════════
// SEGURIDAD — Rate limiting de intentos de login
// Persiste entre instancias serverless (Vercel Fluid Compute)
// ══════════════════════════════════════════════════════

model BarberLoginAttempt {
  id          Int      @id @default(autoincrement())
  ip          String
  slug        String   // tenant slug — limita por IP+tenant
  failedAt    DateTime @default(now())

  @@index([ip, slug])
  @@index([failedAt])
  @@map("barber_login_attempts")
}
