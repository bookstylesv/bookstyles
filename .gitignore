# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — secrets are never committed
.env
.env.local
.env.*.local
# .env.example IS committed (no secrets, serves as template)
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

.vercel
json_dte/*.json

# Claude Code / IA — nunca subir al repositorio público
.agent/
.claude/
CLAUDE.md
skills-lock.json

# Scripts one-shot con datos de instancia específica (contraseñas hardcodeadas)
scripts/create-salon.ts

# Carpetas temporales
tmp-app/

.vercel
